rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /stores/pitamediterranean-athens/app/schedule {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
          "ciwa09@gmail.com"
        ];
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
